{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run lint"
      ]
    }
  ],
  "emulators": {
    "functions": {
      "port": 5001
    },
    "storage": {
      "port": 9199
    },
    "ui": {
      "enabled": true
    },
    "singleProjectMode": true,
    "firestore": {
      "port": 8080
    }
  },
  "firestore": {
    "indexes": [
      {
        "collectionGroup": "RankingEntries",
        "queryScope": "COLLECTION",
        "fields": [
          { "fieldPath": "city", "order": "ASCENDING" },
          { "fieldPath": "averageDelta", "order": "ASCENDING" }
        ]
      },
      {
        "collectionGroup": "RankingEntries",
        "queryScope": "COLLECTION",
        "fields": [
          { "fieldPath": "city", "order": "ASCENDING" },
          { "fieldPath": "averageDelta", "order": "DESCENDING" }
        ]
      }
    ]
  },
  "storage": {
    "rules": "storage.rules"
  }
}
